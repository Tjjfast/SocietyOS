generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Society {
  id        String   @id @default(uuid())
  name      String
  address   String
  createdAt DateTime @default(now())
  flats     Flat[]
  users     User[]
}

model Flat {
  id        String   @id @default(uuid())
  number    String
  floor     Int
  societyId String
  society   Society  @relation(fields: [societyId], references: [id])
  users     User[]
  complaints Complaint[]
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  phone        String?
  role         Role     @default(RESIDENT)
  status       UserStatus @default(PENDING)
  flatId       String?
  flat         Flat?    @relation(fields: [flatId], references: [id])
  societyId    String
  society      Society  @relation(fields: [societyId], references: [id])
  fcmToken     String?
  createdAt    DateTime @default(now())
  complaints   Complaint[]
  entryRequests EntryRequest[]
}

model Complaint {
  id          String          @id @default(uuid())
  title       String
  description String
  category    ComplaintCategory
  status      ComplaintStatus @default(CREATED)
  flatId      String
  flat        Flat            @relation(fields: [flatId], references: [id])
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  assignedTo  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model EntryRequest {
  id          String        @id @default(uuid())
  visitorName String
  visitorPhone String?
  purpose     String?
  status      EntryStatus   @default(PENDING)
  qrToken     String?
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  createdAt   DateTime      @default(now())
  expiresAt   DateTime?
}

enum Role {
  ADMIN
  RESIDENT
  SECURITY
  SERVICE
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  CREATED
  ASSIGNED
  IN_PROGRESS
  USER_CONFIRMED
  CLOSED
}

enum ComplaintCategory {
  PLUMBING
  ELECTRICAL
  CLEANING
  SECURITY
  OTHER
}

enum EntryStatus {
  PENDING
  APPROVED
  REJECTED
  SCANNED
  EXPIRED
}