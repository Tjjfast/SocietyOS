generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Society {
  id        String   @id @default(uuid())
  name      String
  address   String
  zipCode   String?
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  flats     Flat[]
  users     User[]
  passes    Pass[]
  entryLogs EntryLog[]
  notices   Notice[]
  complaints Complaint[]
}

model Flat {
  id        String   @id @default(uuid())
  number    String
  floor     Int
  societyId String
  society   Society  @relation(fields: [societyId], references: [id])
  users     User[]
  complaints Complaint[]
  passes     Pass[]
  entryLogs  EntryLog[]

  @@index([societyId])
  @@unique([number, societyId])
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  phone        String?
  role         Role       @default(RESIDENT)
  status       UserStatus @default(PENDING)
  flatId       String?
  flat         Flat?      @relation(fields: [flatId], references: [id])
  societyId    String
  society      Society    @relation(fields: [societyId], references: [id])
  fcmToken     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  complaints   Complaint[]
  passes       Pass[]
  guardEntries EntryLog[] @relation("GuardEntries")
  residentEntries EntryLog[] @relation("ResidentEntries")
  notices      Notice[]
  notifications Notification[]

  @@index([societyId, status])
  @@index([flatId])
}

model Pass {
  id            String      @id @default(uuid())
  type          PassType
  visitorName   String
  visitorPhone  String?
  visitorType   VisitorType
  notes         String?
  visitorPhoto  String?

  qrToken       String?     @unique
  expiresAt     DateTime?
  status        PassStatus  @default(ACTIVE)

  allowedDays   Int[]
  windowStart   String?
  windowEnd     String?
  validFrom     DateTime?
  validUntil    DateTime?

  residentId    String
  resident      User        @relation(fields: [residentId], references: [id])
  flatId        String
  flat          Flat        @relation(fields: [flatId], references: [id])
  societyId     String
  society       Society     @relation(fields: [societyId], references: [id])
  entries       EntryLog[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([residentId])
  @@index([societyId])
  @@index([flatId])
  @@index([status])
}

model EntryLog {
  id           String      @id @default(uuid())
  visitorName  String
  visitorPhone String?
  visitorType  VisitorType
  method       EntryMethod
  status       EntryStatus
  notes        String?
  visitorIdUrl String?

  passId       String?
  pass         Pass?       @relation(fields: [passId], references: [id])
  guardId      String
  guard        User        @relation("GuardEntries", fields: [guardId], references: [id])
  residentId   String?
  resident     User?       @relation("ResidentEntries", fields: [residentId], references: [id])
  flatId       String
  flat         Flat        @relation(fields: [flatId], references: [id])
  societyId    String
  society      Society     @relation(fields: [societyId], references: [id])

  entryTime    DateTime    @default(now())
  exitTime     DateTime?

  @@index([societyId, entryTime])
  @@index([flatId])
  @@index([guardId])
  @@index([passId])
}

model Notice {
  id         String          @id @default(uuid())
  title      String
  body       String
  category   NoticeCategory
  priority   NoticePriority
  isPinned   Boolean         @default(false)
  authorId   String
  author     User            @relation(fields: [authorId], references: [id])
  societyId  String
  society    Society         @relation(fields: [societyId], references: [id])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([societyId])
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  type       String
  title      String
  body       String
  isRead     Boolean   @default(false)
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([userId, isRead])
}

model Complaint {
  id          String            @id @default(uuid())
  title       String
  description String
  category    ComplaintCategory
  status      ComplaintStatus   @default(OPEN)
  photos      String[]
  closingNote String?
  flatId      String
  flat        Flat              @relation(fields: [flatId], references: [id])
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  societyId   String
  society     Society           @relation(fields: [societyId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([societyId])
  @@index([userId])
}

enum Role {
  ADMIN
  RESIDENT
  SECURITY
  SERVICE
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  OPEN
  CLOSED
}

enum ComplaintCategory {
  PLUMBING
  ELECTRICAL
  CLEANING
  SECURITY
  OTHER
}

enum EntryStatus {
  PENDING
  APPROVED
  REJECTED
  SCANNED
  EXPIRED
}

enum PassType {
  ONE_TIME
  RECURRING
}

enum PassStatus {
  ACTIVE
  USED
  REVOKED
  EXPIRED
}

enum VisitorType {
  DELIVERY
  CAB
  HOUSEHOLD_WORKER
  GUEST
  SERVICE_PROFESSIONAL
}

enum EntryMethod {
  QR_SCAN
  MANUAL_LOOKUP
  LIVE_APPROVAL
}

enum NoticeCategory {
  GENERAL
  MAINTENANCE
  EVENT
  EMERGENCY
}

enum NoticePriority {
  NORMAL
  HIGH
  URGENT
}